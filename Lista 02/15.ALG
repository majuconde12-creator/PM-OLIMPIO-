Algoritmo "15"
// Disciplina  : Lógica de Programaçăo
// Professor   : André Olímpio 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 05/03/2026
var
   n, cont, a, b, c, pares : inteiro

inicio
   escreval("Quantos termos vocę quer ver? ")
   leia(n)

   a <- 0
   b <- 1
   pares <- 0

   escreval("Sequęncia: ")

   para cont de 1 ate n faca
      escreval(a, " ")

      se a % 2 = 0 entao
         pares <- pares + 1
      fimse

      c <- a + b
      a <- b
      b <- c
   fimpara

   escreval("")
   escreval("Quantidade de números pares: ", pares)
fimalgoritmo
