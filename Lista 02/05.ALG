Algoritmo "fatorial_validaçao"
// 
//  
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 27/02/2026
Var
// Seçăo de Declaraçőes das variáveis 
n, i: inteiro
   fatorial: real


Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
  repita
      escreva("Digite um numero inteiro positivo: ")
      leia(n)

      se (n < 0) entao
         escreval("Erro: O numero deve ser positivo.")
      fimse
   ate (n >= 0)

   fatorial <- 1

   se (n > 0) entao
      para i de 1 ate n faca
         fatorial <- fatorial * i
      fimpara
   fimse

      escreval("O fatorial de ", n, " e: ", fatorial)

fimalgoritmo
