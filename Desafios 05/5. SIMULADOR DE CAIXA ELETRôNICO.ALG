Algoritmo "5. Simulador de Caixa Eletrônico"
// Disciplina  : Lógica de Programaçăo
// Professor   : André Olímpio 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 06/03/2026
var
   valor, resto: inteiro
   nota100, nota50, nota20, nota10, nota5, nota2: inteiro

Inicio

   escreva("Digite o valor que deseja sacar (entre 10 e 1000): ")
   leia(valor)

   se (valor < 10) ou (valor > 1000) entao
      escreval("Valor inválido. Digite um valor entre 10 e 1000.")
   senao

      resto <- valor

      nota100 <- resto div 100
      resto <- resto mod 100

      nota50 <- resto div 50
      resto <- resto mod 50

      nota20 <- resto div 20
      resto <- resto mod 20

      nota10 <- resto div 10
      resto <- resto mod 10

      nota5 <- resto div 5
      resto <- resto mod 5

      nota2 <- resto div 2
      resto <- resto mod 2

      escreval("----- Notas entregues -----")

      se (nota100 > 0) entao
         escreval(nota100, " nota(s) de 100")
      fimse

      se (nota50 > 0) entao
         escreval(nota50, " nota(s) de 50")
      fimse

      se (nota20 > 0) entao
         escreval(nota20, " nota(s) de 20")
      fimse

      se (nota10 > 0) entao
         escreval(nota10, " nota(s) de 10")
      fimse

      se (nota5 > 0) entao
         escreval(nota5, " nota(s) de 5")
      fimse

      se (nota2 > 0) entao
         escreval(nota2, " nota(s) de 2")
      fimse

   fimse

Fimalgoritmo

