<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Make Chique</title>

<style>


body{
    font-family: Arial;
    background:#daafbf;
    margin:0;
}


header{
    text-align:center;
    background:#daafbf;
    padding:40px;
}


header img{
    max-width:450px;
    width:100%;
}


.agradecimento{
    text-align:center;
    font-size:20px;
    color:#ffffff;
    margin:10px;
}

.secao{
    text-align:center;
    margin:20px;
}

.botao{
    display:inline-block;
    background-color:#ff69b4;
    color:white;
    padding:10px 20px;
    margin:10px;
    text-decoration:none;
    border-radius:20px;
    font-size:18px;
    transition:0.3s;
}

.botao:hover{
    background-color:#ff1493;
    transform:scale(1.05);
}


.produtos{
    display:grid;
    grid-template-columns: repeat(2, 1fr);
    gap:25px;
    padding:20px;
    max-width:800px;
    margin:auto;
}


.produto-link{
    text-decoration:none;
}


.card{
    transition:0.3s;
}

.card:hover{
    transform:scale(1.05);
}


.card img{
    width:100%;
    height:250px;
    object-fit:cover;
    border-radius:15px;
    box-shadow:0 8px 20px rgba(0,0,0,0.25);
}

</style>
</head>

<body>

    

<header>
<img src="fotos/logo.png">
</header>

<div class="agradecimento">
    Obrigada pela preferência, pelo apoio e carinho! <p>Amo todos vocês 💖</p>
</div>

<div class="secao">
    <a class="botao" href="index.html">Voltar</a>
</div>
<Center>
<audio controls autoplay loop>
    <source src="fotos/doja cat.m4a" type="audio/mpeg">
</audio> </Center>

<div class="produtos">

<a href="Rodas.html" class="produto-link">
<div class="card">
<img src="cliente/gab.png">
</div>
</a>

<a href="RODA.html" class="produto-link">
<div class="card">
<img src="cliente/ruti.png">
</div>
</a>

<a href="#" class="produto-link">
<div class="card">
<img src="cliente/circus.png">
</div>
</a>

<a href="#" class="produto-link">
<div class="card">
<img src="cliente/roro.png">
</div>
</a>

<a href="Bermuda.html" class="produto-link">
<div class="card">
<img src="cliente/Xana.png">
</div>
</a>

<a href="#" class="produto-link">
<div class="card">
<img src="cliente/nick.png">
</div>
</a>

<a href="#" class="produto-link">
<div class="card">
<img src="cliente/bianquinha.png">
</div>
</a>

<a href="#" class="produto-link">
<div class="card">
<img src="cliente/margarete.png">
</div>
</a>

