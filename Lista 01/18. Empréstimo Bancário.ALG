Algoritmo "18. Empréstimo Bancário"
// Disciplina  : Lógica de Programaçăo
// Professor   : André Olímpio 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 23/02/2026
Var
// Seçăo de Declaraçőes das variáveis 
   salario: real
   parcela: real


Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o salario: ")
   leia(salario)

   escreva("Digite o valor da parcela: ")
   leia(parcela)

   se (parcela <= salario * 0.30) entao
      escreva("Emprestimo APROVADO.")
   senao
      escreva("Emprestimo NEGADO.")
   fimse

Fimalgoritmo