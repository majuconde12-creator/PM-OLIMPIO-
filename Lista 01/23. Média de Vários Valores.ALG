Algoritmo "media_valores"
// 
//  
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 23/02/2026
Var
// Seçăo de Declaraçőes das variáveis
     valor1, valor2, valor3, valor4, valor5, media: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
     escreva("Qual o 1° valor: ")
     leia(valor1)
     escreva("Qual o 2° valor: ")
     leia(valor2)
     escreva("Qual o 3° valor: ")
     leia(valor3)
     escreva("Qual o 4° valor: ")
     leia(valor4)
     escreva("Qual o 5° valor: ")
     leia(valor5)
     
     media <- (valor1+valor2+valor3+valor4+valor5)/5
     
     escreva("A media dos numeros é: ", media)


Fimalgoritmo